rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function canReadPostId(postId) {
      let p = get(/databases/$(database)/documents/posts/$(postId));
      return p.data.status == 'approved'
        || (signedIn() && p.data.authorId == request.auth.uid)
        || isAdmin();
    }
    /** 승인된 글이면서 Q&A가 켜진 글에만 새 댓글 허용 */
    function postAllowsNewComments(postId) {
      let p = get(/databases/$(database)/documents/posts/$(postId));
      return p.data.status == 'approved' && !(p.data.commentsEnabled == false);
    }

    /** 관리자_ 형식은 admins 문서가 있는 요청만 허용 */
    function rewardCost(key) {
      return key == 'chupa' ? 5
        : key == 'gift_1000' ? 10
        : key == 'gift_2000' ? 20
        : key == 'gift_5000' ? 50
        : key == 'gift_10000' ? 100
        : -1;
    }

    function validNickname(nickname) {
      return nickname is string
        && (nickname.matches('^학밖청_[가-힣A-Za-z0-9]{2,3}$')
          || nickname.matches('^전문가_[가-힣A-Za-z0-9]{2,3}$')
          || (isAdmin()
            && nickname.matches('^관리자_[가-힣A-Za-z0-9]{2,3}$')));
    }

    match /posts/{postId} {
      allow read: if resource.data.status == 'approved'
        || (signedIn() && resource.data.authorId == request.auth.uid)
        || isAdmin();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && (
          request.resource.data.status == 'pending'
          || (isAdmin() && request.resource.data.category == '공지' && request.resource.data.status == 'approved')
        )
        && (request.resource.data.category != '공지' || isAdmin())
        && request.resource.data.keys().hasAll([
          'title', 'content', 'category', 'region', 'authorId', 'status', 'createdAt', 'commentsEnabled'
        ]);
      allow update: if (isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
        || (signedIn()
          && resource.data.authorId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.status == 'pending'
          && (request.resource.data.category != '공지' || isAdmin())
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title', 'content', 'category', 'region', 'commentsEnabled', 'updatedAt'
          ]));
      allow delete: if isAdmin()
        || (signedIn() && resource.data.authorId == request.auth.uid);
    }

    /** 댓글이 달린 글 문서 (삭제 권한 판별용) */
    function commentParentPost() {
      return get(/databases/$(database)/documents/posts/$(resource.data.postId));
    }

    match /comments/{commentId} {
      allow read: if canReadPostId(resource.data.postId);
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'postId', 'content', 'authorId', 'createdAt', 'parentId'
        ])
        && canReadPostId(request.resource.data.postId)
        && postAllowsNewComments(request.resource.data.postId);
      allow delete: if isAdmin()
        || (signedIn() && resource.data.authorId == request.auth.uid)
        || (
          signedIn()
          && exists(/databases/$(database)/documents/posts/$(resource.data.postId))
          && commentParentPost().data.authorId == request.auth.uid
        );
      allow update: if (
        (
          signedIn()
          && resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.postId == resource.data.postId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'updatedAt'])
        )
        || (
          isAdmin()
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.postId == resource.data.postId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'updatedAt'])
        )
      );
    }

    match /postReports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.reportType in [
          '스팸/홍보',
          '욕설/비방',
          '음란/선정적',
          '허위 정보',
          '기타'
        ]
        && request.resource.data.status == 'open'
        && request.resource.data.keys().hasAll([
          'postId', 'reporterId', 'reportType', 'status', 'createdAt'
        ])
        && reportId == (request.resource.data.postId + '_' + request.auth.uid)
        && canReadPostId(request.resource.data.postId);
      allow read: if isAdmin()
        || (signedIn() && (resource == null || resource.data.reporterId == request.auth.uid));
      allow update: if isAdmin()
        && request.resource.data.postId == resource.data.postId
        && request.resource.data.reporterId == resource.data.reporterId
        && request.resource.data.reportType == resource.data.reportType
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'resolvedAt', 'resolvedBy'
        ]);
      allow delete: if isAdmin();
    }

    match /postLikes/{likeId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['postId', 'userId', 'createdAt'])
        && likeId == (request.resource.data.postId + '_' + request.auth.uid)
        && canReadPostId(request.resource.data.postId);
      allow update: if false;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /postBookmarks/{bookmarkId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['postId', 'userId', 'createdAt'])
        && bookmarkId == (request.resource.data.postId + '_' + request.auth.uid)
        && canReadPostId(request.resource.data.postId);
      allow update: if false;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /rewardRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 9
        && request.resource.data.phone.size() <= 20
        && request.resource.data.status == 'open'
        && request.resource.data.costPoints is int
        && request.resource.data.costPoints == rewardCost(request.resource.data.rewardKey)
        && request.resource.data.rewardKey in [
          'chupa',
          'gift_1000',
          'gift_2000',
          'gift_5000',
          'gift_10000'
        ]
        && request.resource.data.rewardName is string
        && request.resource.data.rewardName.size() > 0
        && request.resource.data.keys().hasAll([
          'userId', 'phone', 'rewardKey', 'rewardName', 'costPoints', 'status', 'createdAt'
        ]);
      allow read: if isAdmin();
      allow update: if isAdmin()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.phone == resource.data.phone
        && request.resource.data.rewardKey == resource.data.rewardKey
        && request.resource.data.rewardName == resource.data.rewardName
        && request.resource.data.costPoints == resource.data.costPoints
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'fulfilledAt', 'fulfilledBy'
        ]);
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if signedIn()
        && (request.auth.uid == uid || isAdmin());
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasAny(['nickname', 'points'])
        && (!('points' in request.resource.data)
          || (request.resource.data.points is int
            && request.resource.data.points == 10))
        && (!('nickname' in request.resource.data)
          || validNickname(request.resource.data.nickname));
      allow update: if (signedIn()
        && request.auth.uid == uid
        && (
          !('points' in request.resource.data)
          || (
            !('points' in resource.data)
            && request.resource.data.points is int
            && request.resource.data.points == 10
          )
          || (
            ('points' in resource.data)
            && request.resource.data.points is int
            && request.resource.data.points >= 0
            && request.resource.data.points <= resource.data.points
          )
        )
        && (
          !('nickname' in request.resource.data)
          || validNickname(request.resource.data.nickname)
        ))
        || (
          isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points'])
          && request.resource.data.points is int
          && (
            (!resource.data.keys().hasAny(['points']) && request.resource.data.points == 1)
            || (
              resource.data.keys().hasAny(['points'])
              && resource.data.points is int
              && request.resource.data.points == resource.data.points + 1
            )
          )
        );
      allow delete: if false;
    }

    match /analyticsDaily/{docId} {
      allow read: if isAdmin();
      // 요약 문서(YYYY-MM-DD): visits +1 및 updatedAt만 허용
      allow create: if signedIn()
        && (docId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
          || (request.resource.data.userId == request.auth.uid));
      allow update: if signedIn()
        && docId.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visits', 'updatedAt'])
        && request.resource.data.visits is int
        && resource.data.visits is int
        && request.resource.data.visits == resource.data.visits + 1;
      allow delete: if false;
    }

    match /analyticsTotals/{docId} {
      allow read: if isAdmin();
      allow create: if signedIn();
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'updatedAt'])
        && request.resource.data.count is int
        && resource.data.count is int
        && request.resource.data.count == resource.data.count + 1;
      allow delete: if false;
    }

    match /nicknames/{nickname} {
      allow read: if signedIn();
      allow create: if signedIn()
        && validNickname(nickname)
        && !exists(/databases/$(database)/documents/nicknames/$(nickname))
        && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
