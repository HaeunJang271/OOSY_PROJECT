rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function canReadPostId(postId) {
      let p = get(/databases/$(database)/documents/posts/$(postId));
      return p.data.status == 'approved'
        || (signedIn() && p.data.authorId == request.auth.uid)
        || isAdmin();
    }
    /** 승인된 글이면서 Q&A가 켜진 글에만 새 댓글 허용 */
    function postAllowsNewComments(postId) {
      let p = get(/databases/$(database)/documents/posts/$(postId));
      return p.data.status == 'approved' && !(p.data.commentsEnabled == false);
    }

    /** 관리자_ 형식은 admins 문서가 있는 요청만 허용 */
    function validNickname(nickname) {
      return nickname is string
        && (nickname.matches('^학밖청_[가-힣A-Za-z0-9]{2,3}$')
          || nickname.matches('^전문가_[가-힣A-Za-z0-9]{2,3}$')
          || (isAdmin()
            && nickname.matches('^관리자_[가-힣A-Za-z0-9]{2,3}$')));
    }

    match /posts/{postId} {
      allow read: if resource.data.status == 'approved'
        || (signedIn() && resource.data.authorId == request.auth.uid)
        || isAdmin();
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
          'title', 'content', 'category', 'region', 'authorId', 'status', 'createdAt', 'commentsEnabled'
        ]);
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin()
        || (signedIn() && resource.data.authorId == request.auth.uid);
    }

    match /comments/{commentId} {
      allow read: if canReadPostId(resource.data.postId);
      allow create: if signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'postId', 'content', 'authorId', 'createdAt', 'parentId'
        ])
        && canReadPostId(request.resource.data.postId)
        && postAllowsNewComments(request.resource.data.postId);
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if signedIn()
        && (request.auth.uid == uid || isAdmin());
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasAny(['nickname'])
        && (!('nickname' in request.resource.data)
          || validNickname(request.resource.data.nickname));
      allow update: if signedIn()
        && request.auth.uid == uid
        && (
          !('nickname' in request.resource.data)
          || validNickname(request.resource.data.nickname)
        );
      allow delete: if false;
    }

    match /nicknames/{nickname} {
      allow read: if signedIn();
      allow create: if signedIn()
        && validNickname(nickname)
        && !exists(/databases/$(database)/documents/nicknames/$(nickname))
        && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }
  }
}
